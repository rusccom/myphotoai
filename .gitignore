# Ignore Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Ignore virtual environment
venv/
env/
.venv/

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore IDE files
.idea/
.vscode/

# Ignore sensitive information
.env
*.log
logs/
instance/
*.db
*.db-journal
*.sqlite
*.sqlite3

# Cursor IDE: images copied from workspaceStorage into project /assets
assets/c__Users_User_AppData_Roaming_Cursor_User_workspaceStorage_*
assets/*workspaceStorage*_images_image-*.png

# Ignore frontend build artifacts
frontend/node_modules/
frontend/build/
frontend/.pnp.cjs
frontend/.pnp.loader.mjs
frontend/coverage/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Xcode
#
# gitignore contributors: remember to keep this file simple and well-commented.
#
# Swift Package Manager
#
# Add this line if you want to avoid checking in source code from Swift Package Manager dependencies.
# Packages/
# Package.pins
# Package.resolved
# *.xcodeproj
# project.xcworkspace
#
# Xcode
#
build/
DerivedData/
#
# Various settings
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
#
# Other
#
*.moved-aside
*.xccoverage
*.app
*.ipa

# Pods
#
# We recommend against adding the Pods directory to your .gitignore. However
# you should judge for yourself, the pros and cons are mentioned at:
# https://guides.cocoapods.org/using/using-cocoapods.html#should-i-check-the-pods-directory-into-source-control
#
# Pods/

# Carthage
#
# Add this line if you want to avoid checking in source code from Carthage dependencies.
# Carthage/Checkouts
Carthage/Build

# fastlane
#
# It is recommended to not store the screenshots in the git repo. Instead, use fastlane to re-generate the
# screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

# End of https://www.toptal.com/developers/gitignore/api/swift,xcode 