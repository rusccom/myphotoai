# Ignore Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Ignore virtual environment
venv/
env/
.venv/

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore IDE files
.idea/
.vscode/

# Ignore sensitive information
.env
*.log
logs/
instance/
*.db
*.db-journal
*.sqlite
*.sqlite3

